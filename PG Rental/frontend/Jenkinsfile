pipeline {
    agent any

    stages {

        stage('Show Files') {
            steps {
                bat 'dir'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('PG Rental/frontend') {
                    bat 'npm install'
                }
            }
        }

        stage('Build Project') {
            steps {
                dir('PG Rental/frontend') {
                    bat 'npm run build'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('PG Rental/frontend') {
                    bat 'npm test'
                }
            }
        }

    }
}
